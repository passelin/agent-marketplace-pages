---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import manifestData from '../../public/data/manifest.json';

const marketplaceName = manifestData.marketplaceName || 'Plugin Marketplace';
const description = manifestData.description || 'Browse and install plugins for your GitHub Copilot CLI experience';
const counts = manifestData.counts as Record<string, number>;

const resourceTypes = [
  { key: 'plugins',      label: 'Plugins',      icon: '🔌', color: '#7c3aed', desc: 'Installable plugin bundles',                href: 'plugins/'      },
  { key: 'agents',       label: 'Agents',        icon: '🤖', color: '#2563eb', desc: 'Custom agents for specialized AI tasks',     href: 'agents/'       },
  { key: 'instructions', label: 'Instructions',  icon: '📋', color: '#0891b2', desc: 'Coding standards and best practices',        href: 'instructions/' },
  { key: 'skills',       label: 'Skills',        icon: '⚡', color: '#ca8a04', desc: 'Self-contained skill folders',               href: 'skills/'       },
  { key: 'hooks',        label: 'Hooks',         icon: '🪝', color: '#c2410c', desc: 'Automations triggered by agent events',      href: 'hooks/'        },
  { key: 'workflows',    label: 'Workflows',     icon: '⚙️',  color: '#15803d', desc: 'AI-powered automations for GitHub Actions', href: 'workflows/'    },
].filter(r => counts[r.key] > 0);

const total = counts.total ?? Object.values(counts).reduce((a: number, b: number) => a + b, 0);
---

<StarlightPage frontmatter={{ title: marketplaceName, template: 'splash', prev: false, next: false, editUrl: false }}>
  <div id="main-content">
    <div class="page-content">
      <div class="container">
        <div class="marketplace-hero">
          <h1>{marketplaceName}</h1>
          <p class="marketplace-description">{description}</p>

          <div class="global-search-wrap">
            <label for="global-search-input" class="sr-only">Search all resources</label>
            <input
              type="text"
              id="global-search-input"
              class="global-search-input"
              placeholder={`Search across all ${total} resources...`}
              autocomplete="off"
            />
            <div id="global-search-results" class="global-search-results" hidden></div>
          </div>
        </div>

        <section id="categories-section" class="categories-section" aria-labelledby="categories-heading">
          <h2 id="categories-heading">Browse by Type</h2>
          <div class="categories-grid">
            {resourceTypes.map((r, i) => (
              <a
                href={r.href}
                class="category-card"
                style={`--cat-color: ${r.color}; --animation-delay: ${i * 60}ms;`}
              >
                <span class="category-icon" aria-hidden="true">{r.icon}</span>
                <span class="category-name">{r.label}</span>
                <span class="category-desc">{r.desc}</span>
                <span class="category-count">{counts[r.key] ?? 0}</span>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>

  <script>import '../scripts/global-search';</script>

  <style>
    .marketplace-hero {
      text-align: center;
      padding: 60px 0 48px;
    }

    /* ── Global search ── */
    .global-search-wrap {
      position: relative;
      max-width: 560px;
      margin: 32px auto 0;
    }
    .global-search-input {
      width: 100%;
      padding: 12px 20px;
      font-size: 1rem;
      border: 1px solid var(--color-glass-border);
      border-radius: var(--border-radius-lg);
      background: var(--color-card-bg);
      color: var(--color-text);
      outline: none;
      box-sizing: border-box;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .global-search-input:focus {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 20%, transparent);
    }
    .global-search-results {
      position: absolute;
      top: calc(100% + 6px);
      left: 0; right: 0;
      background: var(--color-card-bg);
      border: 1px solid var(--color-glass-border);
      border-radius: var(--border-radius-lg);
      box-shadow: 0 8px 32px -8px rgba(0,0,0,0.25);
      z-index: 100;
    }
    .marketplace-hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 800;
      color: var(--color-text-emphasis);
      margin-bottom: 16px;
    }
    .marketplace-description {
      font-size: 1.1rem;
      color: var(--color-text-muted);
      max-width: 560px;
      margin: 0 auto 40px;
      line-height: 1.6;
    }
    .stats-row {
      display: flex;
      justify-content: center;
      gap: 16px;
      margin-bottom: 0;
      flex-wrap: wrap;
    }
    .stat-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      background: var(--color-card-bg);
      border: 1px solid var(--color-glass-border);
      border-radius: var(--border-radius-lg);
      padding: 16px 24px;
      min-width: 100px;
    }
    .stat-number {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--color-accent);
      line-height: 1;
    }
    .stat-label {
      font-size: 0.8rem;
      color: var(--color-text-muted);
      margin-top: 4px;
    }

    .categories-section {
      margin: 48px 0 80px;
    }
    .categories-section h2 {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--color-text-emphasis);
      margin-bottom: 20px;
      text-align: center;
    }
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 16px;
    }
    .category-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 28px 16px 20px;
      background: var(--color-card-bg);
      border: 1px solid var(--color-glass-border);
      border-radius: var(--border-radius-lg);
      text-decoration: none;
      color: var(--color-text);
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
      animation: card-fade-in 0.4s ease both;
      animation-delay: var(--animation-delay, 0ms);
    }
    .category-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: var(--cat-color);
      transition: height var(--transition);
    }
    .category-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px -8px var(--cat-color);
      border-color: var(--cat-color);
      color: var(--color-text-emphasis);
    }
    .category-card:hover::after { height: 4px; }
    .category-icon {
      font-size: 2.25rem;
      line-height: 1;
      position: relative;
      z-index: 1;
    }
    .category-name {
      font-size: 1rem;
      font-weight: 700;
      text-align: center;
      color: var(--color-text-emphasis);
      position: relative;
      z-index: 1;
    }
    .category-desc {
      font-size: 0.78rem;
      text-align: center;
      color: var(--color-text-muted);
      line-height: 1.3;
      position: relative;
      z-index: 1;
    }
    .category-count {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--cat-color);
      background: color-mix(in srgb, var(--cat-color) 15%, transparent);
      border-radius: 12px;
      padding: 2px 12px;
      position: relative;
      z-index: 1;
      margin-top: 4px;
    }
    @keyframes card-fade-in {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @media (max-width: 640px) {
      .categories-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
      .stats-row { gap: 10px; }
      .stat-card { padding: 12px 16px; min-width: 80px; }
    }
  </style>
</StarlightPage>
