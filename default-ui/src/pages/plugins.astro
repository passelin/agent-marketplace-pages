---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import pluginsData from '../../public/data/plugins.json';
import manifestData from '../../public/data/manifest.json';
import EmbeddedPageData from '../components/EmbeddedPageData.astro';
import ResourceNav from '../components/ResourceNav.astro';
import { renderPluginsHtml } from '../scripts/plugins-render';

const initialItems = pluginsData.items;
const marketplaceName = manifestData.marketplaceName || 'this marketplace';
---

<StarlightPage frontmatter={{ title: 'Plugins', description: 'Browse and install plugins', template: 'splash', prev: false, next: false, editUrl: false }}>
  <div id="main-content">
    <div class="page-content">
      <div class="container">
        <ResourceNav currentType="plugin" />
        <div class="page-header">
          <div class="page-header-row">
            <div>
              <h1>Plugins</h1>
              <p>Browse and install plugins from {marketplaceName}</p>
            </div>
          </div>
        </div>

        <div class="how-to-install">
          <p>Install any plugin with: <code>copilot plugin install &lt;plugin-name&gt;@{marketplaceName}</code></p>
        </div>

        <div class="listing-toolbar">
          <div class="search-bar">
            <label for="search-input" class="sr-only">Search plugins</label>
            <input type="text" id="search-input" placeholder="Search plugins..." autocomplete="off" />
          </div>

          <div class="filters-bar" id="filters-bar">
            <div class="filter-group">
              <label for="filter-tag">Tag:</label>
              <select id="filter-tag" multiple aria-label="Filter by tag"></select>
            </div>
            <div class="filter-group">
              <label for="filter-category">Category:</label>
              <select id="filter-category" multiple aria-label="Filter by category"></select>
            </div>
            <div class="filter-group">
              <label for="filter-source">Source:</label>
              <select id="filter-source" multiple aria-label="Filter by source"></select>
            </div>
            <button id="clear-filters" class="btn btn-secondary btn-small">Clear Filters</button>
          </div>
        </div>

        <div class="results-count" id="results-count" aria-live="polite">
          {initialItems.length} of {initialItems.length} plugins
        </div>

        <div class="resource-list" id="resource-list" role="list" set:html={renderPluginsHtml(initialItems, { marketplaceName })}></div>
      </div>
    </div>
  </div>

  <div id="marketplace-config" data-marketplace-name={marketplaceName} hidden></div>

  <EmbeddedPageData filename="plugins.json" data={pluginsData} />

  <script>
    import '../scripts/plugins';
  </script>

  <style>
    .how-to-install {
      background: var(--sl-color-bg-nav);
      border: 1px solid var(--sl-color-hairline);
      border-radius: 0.5rem;
      padding: 0.75rem 1.25rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }
    .how-to-install p { margin: 0; }
    .how-to-install code {
      background: var(--sl-color-bg-inline-code);
      padding: 0.1em 0.35em;
      border-radius: 0.2rem;
      font-size: 0.85em;
    }
  </style>
</StarlightPage>
